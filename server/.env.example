# Server
PORT=3005
NODE_ENV=development
APP_ORIGIN=http://localhost:3000
PUBLIC_CORS=*

# Database (Prisma reads DATABASE_URL)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/kaligan?schema=public
EMBEDDING_DIM=384

# Auth
JWT_ACCESS_SECRET=your_super_secret_access_token_key_change_me_in_production
JWT_REFRESH_SECRET=your_super_secret_refresh_token_key_change_me_in_production
ACCESS_TTL=900
REFRESH_TTL=2592000

# Gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_TEXT_MODEL=gemini-2.0-flash
VOICE_MODEL=gemini-2.5-flash-native-audio-preview-09-2025

# Misc
MAX_UPLOAD_MB=10
RAG_TOP_K=5
RAG_THRESHOLD=0.35
